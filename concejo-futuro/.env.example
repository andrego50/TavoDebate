# TavoDebate - Concejo del Futuro
# Copiar a .env y rellenar con valores reales

# Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui
ADMIN_USER_IDS=123456789
ADMIN_CHAT_ID=123456789

# LLM Providers
# vLLM es el modelo local (Gemma 4B). DeepSeek y Kimi son fallback.
VLLM_API_KEY=vllm
VLLM_BASE_URL=http://127.0.0.1:9090/v1
VLLM_MODEL=unsloth/gemma-3-4b-it
LLM_PRIORITY=vllm,deepseek,kimi
DEEPSEEK_API_KEY=tu_key_aqui
KIMI_API_KEY=tu_key_moonshot_aqui
OPENAI_API_KEY=tu_key_aqui_para_whisper

# Database
DATABASE_URL=postgresql+asyncpg://concejo:concejo2026@postgres:5432/concejo_futuro
POSTGRES_PASSWORD=concejo2026

# Redis
REDIS_URL=redis://redis:6379

# Config
BRIEFING_INTERVAL_SECONDS=120
ENVIRONMENT=dev
VPS_DOMAIN=localhost
